{
  "name": "@rothenbergt/backstage-plugin-search-backend-module-roadmap",
  "description": "Search backend module that indexes roadmap features in Backstage search",
  "version": "0.1.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
